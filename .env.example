# ============================================================
# SAP Configuration — copy to .env and fill in your values
# ============================================================

# --- SAP Logon -----------------------------------------------------------
# Full path to the SAP Logon executable
SAP_LOGON_PATH=C:\Program Files (x86)\SAP\FrontEnd\SAPgui\saplogon.exe

# --- Export path ---------------------------------------------------------
# Directory where SAP BOM exports are saved (default: ~/Desktop)
SAP_EXPORT_PATH=

# --- Submaterial extraction path -----------------------------------------
# UNC or local path to submaterial usage files
SAP_EXTRAER_ARCHIVO=\\172.29.172.155\Industrial_Eng\IE-SAP\1) BOM files\e) Submaterial Usage

# --- SAP Credentials (used by Credenciales.json) -------------------------
SAP_SYSTEM_NAME=
SAP_USER=
SAP_PASSWORD=
